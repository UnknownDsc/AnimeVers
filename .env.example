# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Auth
JWT_SECRET=your_jwt_secret_min_32_characters_long

# Anime API
ANIME_API_BASE=https://www.sankavollerei.com/anime

# =========================================
# Cara mendapatkan credentials Supabase:
# =========================================
# 1. Buka https://supabase.com → Project → Settings → API
# 2. SUPABASE_URL       = Project URL (https://xxxxx.supabase.co)
# 3. SUPABASE_SERVICE_ROLE_KEY = service_role key (secret, JANGAN expose ke browser!)
#    ⚠️ BUKAN anon key! Service role key bypass RLS.
# 4. JWT_SECRET = random string minimal 32 karakter (untuk sign JWT token)
